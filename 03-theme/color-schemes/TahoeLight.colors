# Window-manager (titlebar) colors — titlebar reads as light glass.
[WM]
activeBackground=255,255,255
activeForeground=36,36,36
activeBlend=86,86,86
inactiveBackground=245,245,245
inactiveForeground=120,120,120
inactiveBlend=102,102,102

[ColorEffects:Inactive]
Enable=false
ChangeSelectionColor=true
Color=112,111,110
ColorAmount=0.025
ColorEffect=2
ContrastAmount=0.1
ContrastEffect=2
IntensityAmount=0
IntensityEffect=0

[ColorEffects:Disabled]
Color=56,56,56
ColorAmount=0
ColorEffect=0
ContrastAmount=0.65
ContrastEffect=1
IntensityAmount=0.1
IntensityEffect=2

[KDE]
contrast=4
